name: Unzip mywaypoint.zip

on:
  workflow_dispatch:

jobs:
  unzip:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Unzip file
        run: unzip -o mywaypoint.zip

      - name: Remove zip
        run: rm mywaypoint.zip

      - name: Commit and push
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add -A
          git commit -m "Extract mywaypoint.zip" || true
          git push
